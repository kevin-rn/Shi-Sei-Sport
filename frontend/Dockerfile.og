# Stage 1: Build React frontend (shared with caddy/Dockerfile)
FROM node:22-alpine AS frontend-builder
WORKDIR /app
COPY frontend/package*.json ./
RUN npm install && npm cache clean --force
COPY frontend/ .
RUN npm run build

# Stage 2: Run OG injection server
FROM node:22-alpine
WORKDIR /app
COPY --from=frontend-builder /app/dist ./dist
COPY frontend/server.mjs .
EXPOSE 3001
ENV PORT=3001
CMD ["node", "server.mjs"]
